# --- Model provider (pick ONE via MODEL) --------------------------------------
# Provider is auto-detected from the MODEL string; the matching key below is used.

# OpenAI GPT (recommended) — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# xAI Grok (optional) — get a key at https://console.x.ai -> API keys
# XAI_API_KEY=xai-your-key-here

# Choose the model for the analysis agents. Provider is inferred from the prefix.
#   MODEL=gpt-4o-mini   (cheap + fast + very reliable with CrewAI tools) [default]
#   MODEL=gpt-4o        (stronger, pricier)
#   MODEL=xai/grok-3    (non-reasoning Grok; usable)
MODEL=gpt-4o-mini

# Give ONLY the Planner (Phase 1) a different model, if you want. The Planner is
# read-only and benefits from a strong reasoner; leave empty to reuse MODEL.
#   PLANNER_MODEL=gpt-4o
PLANNER_MODEL=

# Give ONLY the Fix Applier a stronger model. It must produce exact edits and
# diagnose test failures; weak models submit broken edits. Recommended: gpt-4o.
# (fix.ps1 / apply.ps1 default this to gpt-4o if left empty.)
#   APPLIER_MODEL=gpt-4o
APPLIER_MODEL=

# --- LLM resilience / rate-limit tuning --------------------------------------
TEMPERATURE=0.1
MAX_TOKENS=4000
# Retry on empty/failed output, linear backoff (seconds); retries escalate temp.
LLM_EMPTY_RETRIES=3
LLM_RETRY_DELAY=3
# litellm-level retries for API errors (429/5xx).
LLM_API_RETRIES=3
# Last-resort model if the primary keeps returning empty content. Unset = auto
# (gpt-4o-mini when OPENAI_API_KEY present). Set "none" to disable.
# FALLBACK_MODEL=gpt-4o-mini
# For xAI "mini" reasoning models only: low|high.
# REASONING_EFFORT=low

# --- Fix-mode caps (only apply when using --fix) ------------------------------
# MAX_FIXES=40      # stop after this many successful edits
# MAX_ROUNDS=1      # fix passes; default 1 (use --rounds N to loop)

# --- Planner (Phase 1) tuning -------------------------------------------------
# Max spec/planning files find_spec_docs will list before it warns (keeps big
# docs trees from flooding the model's context).
# MAX_SPEC_FILES=60

# --- Optional: scope override -------------------------------------------------
# Repo root is auto-detected (parent of this crew/ folder).
# CLARITY_REPO_ROOT=C:\path\to\clarity-rex
